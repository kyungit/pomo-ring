<Window x:Class="PomoRing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PomoRing" Width="490" Height="840" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Cream}"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>
    <Grid Margin="22">
        <Border Background="{StaticResource Ink}" Margin="6,6,-6,-6"/>
        <Border Background="{StaticResource Paper}" BorderBrush="{StaticResource Ink}" BorderThickness="4" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="104"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Canvas Width="96" Height="90" VerticalAlignment="Top">
                        <Rectangle Fill="#403536" Width="12" Height="12" Canvas.Left="18" Canvas.Top="8"/>
                        <Rectangle Fill="#403536" Width="12" Height="12" Canvas.Left="66" Canvas.Top="8"/>
                        <Rectangle Fill="#403536" Width="72" Height="54" Canvas.Left="12" Canvas.Top="20"/>
                        <Rectangle Fill="#D9A77F" Width="60" Height="48" Canvas.Left="18" Canvas.Top="20"/>
                        <Rectangle Fill="#F2C89D" Width="36" Height="30" Canvas.Left="30" Canvas.Top="38"/>
                        <Rectangle Fill="#403536" Width="6" Height="6" Canvas.Left="30" Canvas.Top="38"/>
                        <Rectangle Fill="#403536" Width="6" Height="6" Canvas.Left="60" Canvas.Top="38"/>
                        <Rectangle Fill="#403536" Width="6" Height="6" Canvas.Left="45" Canvas.Top="50"/>
                        <Rectangle Fill="#F38B76" Width="6" Height="6" Canvas.Left="39" Canvas.Top="58"/>
                        <Rectangle Fill="#F38B76" Width="6" Height="6" Canvas.Left="51" Canvas.Top="58"/>
                        <Rectangle Fill="#403536" Width="60" Height="8" Canvas.Left="18" Canvas.Top="74"/>
                    </Canvas>
                    <StackPanel Grid.Column="1" Margin="8,5,0,0">
                        <TextBlock Text="P O M O  R I N G" FontWeight="Black" FontSize="26"/>
                        <TextBlock Text="PIXEL FOCUS BUDDY" FontWeight="Bold" Foreground="{StaticResource Peach}" FontSize="12"/>
                        <Border Background="#FFF0C9" BorderBrush="{StaticResource Ink}" BorderThickness="2" Margin="0,12,0,0" Padding="8,5">
                            <TextBlock x:Name="ProgressText" Text="READY TO FOCUS!" FontSize="11" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="#E9E1C9" Height="3" Margin="0,18,0,16"/>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="01  TIMER MODE" FontWeight="Black" FontSize="13" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border x:Name="CountdownCard" BorderBrush="{StaticResource Ink}" BorderThickness="3" Background="#FFF0C9" Padding="12">
                            <RadioButton x:Name="CountdownRadio" GroupName="TimerMode" IsChecked="True"
                                         Content="COUNTDOWN  카운트다운" Checked="TimerMode_Changed"/>
                        </Border>
                        <Border Grid.Column="2" x:Name="CountupCard" BorderBrush="{StaticResource Ink}" BorderThickness="3" Background="White" Padding="12">
                            <RadioButton x:Name="CountupRadio" GroupName="TimerMode"
                                         Content="COUNT UP  카운트업" Checked="TimerMode_Changed"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="02  PICK YOUR BUDDY" FontWeight="Black" FontSize="13" Margin="0,18,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="CatCard" BorderBrush="{StaticResource Ink}" BorderThickness="3" Background="#FFF0C9" Padding="7">
                            <RadioButton x:Name="CatRadio" GroupName="Character" IsChecked="True" Checked="Character_Changed">
                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="42" Height="32">
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="5" Canvas.Top="1"/>
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="33" Canvas.Top="1"/>
                                        <Rectangle Fill="#403536" Width="8" Height="4" Canvas.Left="5" Canvas.Top="5"/>
                                        <Rectangle Fill="#403536" Width="8" Height="4" Canvas.Left="29" Canvas.Top="5"/>
                                        <Rectangle Fill="#403536" Width="12" Height="4" Canvas.Left="5" Canvas.Top="9"/>
                                        <Rectangle Fill="#403536" Width="12" Height="4" Canvas.Left="25" Canvas.Top="9"/>
                                        <Rectangle Fill="#403536" Width="36" Height="25" Canvas.Left="1" Canvas.Top="7"/>
                                        <Rectangle Fill="#D6A276" Width="28" Height="19" Canvas.Left="5" Canvas.Top="9"/>
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="11" Canvas.Top="16"/>
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="25" Canvas.Top="16"/>
                                    </Canvas>
                                    <TextBlock Text="CAT / 고양이" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </RadioButton>
                        </Border>
                        <Border Grid.Column="2" x:Name="BunnyCard" BorderBrush="{StaticResource Ink}" BorderThickness="3" Background="White" Padding="7">
                            <RadioButton x:Name="BunnyRadio" GroupName="Character" Checked="Character_Changed">
                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="42" Height="32">
                                        <Rectangle Fill="#403536" Width="9" Height="20" Canvas.Left="8" Canvas.Top="0"/>
                                        <Rectangle Fill="#403536" Width="9" Height="20" Canvas.Left="25" Canvas.Top="0"/>
                                        <Rectangle Fill="#403536" Width="34" Height="23" Canvas.Left="4" Canvas.Top="9"/>
                                        <Rectangle Fill="#F1D8C2" Width="26" Height="17" Canvas.Left="8" Canvas.Top="12"/>
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="13" Canvas.Top="18"/>
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="25" Canvas.Top="18"/>
                                    </Canvas>
                                    <TextBlock Text="BUNNY / 토끼" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </RadioButton>
                        </Border>
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="03  SESSION SETUP" FontWeight="Black" FontSize="13" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1" x:Name="CountdownSettings">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource Label}" Text="FOCUS / 집중"/>
                            <DockPanel><TextBox x:Name="FocusMinutesBox" Text="25"/><TextBlock Text=" MIN" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/></DockPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource Label}" Text="BREAK / 휴식"/>
                            <DockPanel><TextBox x:Name="RestMinutesBox" Text="5"/><TextBlock Text=" MIN" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/></DockPanel>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="2" x:Name="RepeatPanel" Margin="0,16,0,0" Padding="12" BorderBrush="{StaticResource Ink}" BorderThickness="3" Background="#E5F1E7">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="95"/></Grid.ColumnDefinitions>
                            <CheckBox x:Name="RepeatCheck" Content="집중 + 휴식 반복" IsChecked="True"
                                      VerticalAlignment="Center" Checked="RepeatCheck_Changed" Unchecked="RepeatCheck_Changed"/>
                            <DockPanel Grid.Column="1"><TextBox x:Name="RepeatCountBox" Text="4"/><TextBlock Text=" 회" FontWeight="Bold" Margin="5,0,0,0" VerticalAlignment="Center"/></DockPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="3" Margin="0,16,0,0">
                        <CheckBox x:Name="ShowTimerCheck" IsChecked="True" Content="버디 위에 시간 표시"/>
                        <TextBlock x:Name="ValidationText" Foreground="#D85D55" FontWeight="Bold" FontSize="11" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="4" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="105"/></Grid.ColumnDefinitions>
                    <Button x:Name="StartButton" Content="▶ START FOCUS" Click="StartButton_Click"/>
                    <Button Grid.Column="2" Content="EXIT" Click="ExitButton_Click" Background="#A99A8E"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
