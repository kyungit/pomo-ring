<Window x:Class="PomoRing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PomoRing" Width="510" Height="820" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Cream}"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,9"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource SoftInk}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ChoiceCard" TargetType="Border">
            <Setter Property="BorderBrush" Value="#CDBBA9"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="11"/>
        </Style>
    </Window.Resources>
    <Grid Margin="22">
        <Border Background="{StaticResource Ink}" Margin="6,6,-6,-6"/>
        <Border Background="{StaticResource Paper}" BorderBrush="{StaticResource Ink}" BorderThickness="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,22">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="82"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Canvas Width="70" Height="66">
                            <Path Data="M7,24 L17,5 L27,24 M43,24 L53,5 L63,24" Fill="#D6A276" Stroke="#403536" StrokeThickness="4" StrokeLineJoin="Round"/>
                            <Rectangle Fill="#403536" Width="62" Height="42" Canvas.Left="4" Canvas.Top="22"/>
                            <Rectangle Fill="#D6A276" Width="54" Height="34" Canvas.Left="8" Canvas.Top="24"/>
                            <Rectangle Fill="#403536" Width="5" Height="6" Canvas.Left="20" Canvas.Top="37"/>
                            <Rectangle Fill="#403536" Width="5" Height="6" Canvas.Left="45" Canvas.Top="37"/>
                            <Rectangle Fill="#F38B76" Width="5" Height="5" Canvas.Left="32" Canvas.Top="47"/>
                        </Canvas>
                        <StackPanel Grid.Column="1" Margin="8,2,0,0">
                            <TextBlock Text="PomoRing" FontWeight="Black" FontSize="24"/>
                            <Border Background="#FFF0C9" CornerRadius="6" Margin="0,8,0,0" Padding="8,5">
                                <TextBlock x:Name="ProgressText" Text="집중할 준비가 됐어요!" FontSize="10"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Background="#E9E1C9" Height="3" Margin="0,17,0,16"/>

                    <TextBlock Style="{StaticResource SectionTitle}" Text="01  버디 고르기"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border x:Name="CatCard" Style="{StaticResource ChoiceCard}" Background="#FFF0C9">
                            <RadioButton x:Name="CatRadio" GroupName="Character" IsChecked="True" Checked="Character_Changed">
                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="48" Height="37">
                                        <Path Data="M4,16 L12,3 L21,16 M27,16 L36,3 L44,16" Fill="#D6A276" Stroke="#403536" StrokeThickness="3" StrokeLineJoin="Round"/>
                                        <Rectangle Fill="#403536" Width="42" Height="25" Canvas.Left="3" Canvas.Top="12"/>
                                        <Rectangle Fill="#D6A276" Width="34" Height="19" Canvas.Left="7" Canvas.Top="15"/>
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="14" Canvas.Top="22"/>
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="30" Canvas.Top="22"/>
                                    </Canvas>
                                    <TextBlock Text="고양이" FontWeight="Bold" FontSize="10" Margin="0,4,0,0"/>
                                </StackPanel>
                            </RadioButton>
                        </Border>
                        <Border Grid.Column="2" x:Name="BunnyCard" Style="{StaticResource ChoiceCard}">
                            <RadioButton x:Name="BunnyRadio" GroupName="Character" Checked="Character_Changed">
                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="48" Height="37">
                                        <Rectangle Fill="#403536" Width="9" Height="22" Canvas.Left="10" Canvas.Top="0"/>
                                        <Rectangle Fill="#403536" Width="9" Height="22" Canvas.Left="29" Canvas.Top="0"/>
                                        <Rectangle Fill="#403536" Width="40" Height="24" Canvas.Left="4" Canvas.Top="13"/>
                                        <Rectangle Fill="#F1D8C2" Width="32" Height="18" Canvas.Left="8" Canvas.Top="16"/>
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="15" Canvas.Top="23"/>
                                        <Rectangle Fill="#403536" Width="4" Height="4" Canvas.Left="29" Canvas.Top="23"/>
                                    </Canvas>
                                    <TextBlock Text="토끼" FontWeight="Bold" FontSize="10" Margin="0,4,0,0"/>
                                </StackPanel>
                            </RadioButton>
                        </Border>
                    </Grid>

                    <TextBlock Style="{StaticResource SectionTitle}" Text="02  타이머 방식" Margin="0,20,0,9"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border x:Name="CountdownCard" Style="{StaticResource ChoiceCard}" Background="#FFF0C9">
                            <RadioButton x:Name="CountdownRadio" GroupName="TimerMode" IsChecked="True"
                                         Content="카운트다운" Checked="TimerMode_Changed"/>
                        </Border>
                        <Border Grid.Column="2" x:Name="CountupCard" Style="{StaticResource ChoiceCard}">
                            <RadioButton x:Name="CountupRadio" GroupName="TimerMode"
                                         Content="카운트업" Checked="TimerMode_Changed"/>
                        </Border>
                    </Grid>

                    <StackPanel x:Name="CountdownSettings" Margin="0,20,0,0">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="03  세션 설정"/>
                        <Border x:Name="PomodoroPanel" Background="#FFF7E5" CornerRadius="10" Padding="13">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="170"/></Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <CheckBox x:Name="PomodoroCheck" Content="뽀모도로" IsChecked="True"
                                              Checked="PomodoroCheck_Changed" Unchecked="PomodoroCheck_Changed"/>
                                    <TextBlock Text="집중과 휴식을 반복해요" FontSize="10" Foreground="{StaticResource SoftInk}"
                                               Margin="26,4,0,0"/>
                                </StackPanel>
                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition Width="35"/></Grid.ColumnDefinitions>
                                    <TextBox x:Name="RepeatCountBox" Text="4" Padding="8,0" MinHeight="42"
                                             TextAlignment="Center" MaxLength="4"/>
                                    <TextBlock Grid.Column="1" Text="회" FontWeight="Bold" Foreground="#A9907E"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Background="#FFF7E5" CornerRadius="10" Padding="13" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Label}" Text="집중 시간"/>
                                    <Grid>
                                        <TextBox x:Name="FocusMinutesBox" Text="50" Padding="12,0,48,0"/>
                                        <TextBlock x:Name="FocusUnitText" Text="분" FontWeight="Bold" Foreground="#A9907E"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2" x:Name="RestTimePanel">
                                    <TextBlock Style="{StaticResource Label}" Text="휴식 시간"/>
                                    <Grid>
                                        <TextBox x:Name="RestMinutesBox" Text="10" Padding="12,0,48,0"/>
                                        <TextBlock x:Name="RestUnitText" Text="분" FontWeight="Bold" Foreground="#A9907E"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="SecondsTestPanel" Visibility="Collapsed" Background="#F6EAF0" CornerRadius="10" Padding="12" Margin="0,10,0,0">
                            <StackPanel>
                                <CheckBox x:Name="SecondsTestCheck" Content="빠른 테스트: 시간을 초 단위로 사용"
                                          Checked="SecondsTestCheck_Changed" Unchecked="SecondsTestCheck_Changed"/>
                                <TextBlock Text="테스트 기록은 누적 집중 시간에 포함되지 않아요." FontSize="10"
                                           Foreground="{StaticResource SoftInk}" Margin="20,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <CheckBox x:Name="ShowTimerCheck" IsChecked="True" Content="버디 위에 시간 표시" Margin="2,15,0,0"/>
                    <TextBlock x:Name="ValidationText" Foreground="#D85D55" FontWeight="Bold" FontSize="11" Margin="0,8,0,0"/>

                    <Grid Margin="0,18,0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="105"/></Grid.ColumnDefinitions>
                        <Button x:Name="StartButton" Content="▶ 집중 시작" Click="StartButton_Click"/>
                        <Button Grid.Column="2" Content="종료" Click="ExitButton_Click" Background="#A99A8E"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
